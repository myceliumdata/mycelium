#!/usr/bin/env python
"""Dev/ops reset for Mycelium canonical data paths (ignores MYCELIUM_* env redirection)."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(REPO_ROOT))

from agents.registry import AgentRegistryData, RegisteredAgent  # noqa: E402

DB_PATH = Path("data/mycelium.db")
CATEGORIES_PATH = Path("data/categories.json")
REGISTRY_PATH = Path("data/agent_registry.json")
SPECIALISTS_DIR = Path("src/agents/specialists")
AGENT_DATA_ROOT = Path("data/agents")
CORE_AGENT_NAME = "core_data"


def _repo_path(rel: str | Path) -> Path:
    return REPO_ROOT / rel


def _in_git_repo() -> bool:
    result = subprocess.run(
        ["git", "rev-parse", "--is-inside-work-tree"],
        cwd=REPO_ROOT,
        capture_output=True,
        text=True,
        check=False,
    )
    return result.returncode == 0 and result.stdout.strip() == "true"


def _git_rm(path: Path, *, recursive: bool = False, dry_run: bool, no_git: bool) -> None:
    rel = path.relative_to(REPO_ROOT)
    flag = "-r" if recursive else "-f"
    cmd = ["git", "rm", flag, "--ignore-unmatch", str(rel)]
    if dry_run or no_git:
        print(f"  [git] (skipped) {' '.join(cmd)}")
        return
    if not _in_git_repo():
        print("  [git] warning: not in a git repository; skipping git rm")
        return
    subprocess.run(cmd, cwd=REPO_ROOT, check=False)


def _remove_path(path: Path, *, dry_run: bool) -> None:
    if dry_run:
        print(f"  [rm] (dry) {path}")
        return
    if path.is_dir():
        shutil.rmtree(path, ignore_errors=True)
    else:
        path.unlink(missing_ok=True)


def _parse_specialist_args(values: list[str]) -> list[str]:
    names: list[str] = []
    seen: set[str] = set()
    for raw in values:
        for part in raw.split(","):
            name = part.strip()
            if not name or name in seen:
                continue
            seen.add(name)
            names.append(name)
    return names


def _load_registry_data() -> AgentRegistryData:
    reg_path = _repo_path(REGISTRY_PATH)
    if reg_path.exists():
        raw = json.loads(reg_path.read_text(encoding="utf-8"))
        return AgentRegistryData.model_validate(raw)
    return AgentRegistryData.model_validate(
        {
            "version": "1.0",
            "last_updated": "2026-06-03T00:00:00+00:00",
            "agents": {},
        },
    )


def _collect_all_specialist_names(data: AgentRegistryData) -> list[str]:
    names = [n for n in data.agents if n != CORE_AGENT_NAME]
    spec_dir = _repo_path(SPECIALISTS_DIR)
    if spec_dir.is_dir():
        for py_file in spec_dir.glob("*_specialist.py"):
            stem = py_file.stem
            if stem.endswith("_specialist") and stem != CORE_AGENT_NAME:
                names.append(stem)
    return sorted(set(names))


def _prune_registry(
    remove_names: set[str],
    *,
    dry_run: bool,
) -> tuple[AgentRegistryData, set[str], bool]:
    current = _load_registry_data()
    categories_to_clean: set[str] = set()
    new_agents: dict[str, RegisteredAgent] = {}
    removed_from_registry: list[str] = []

    if CORE_AGENT_NAME in current.agents:
        new_agents[CORE_AGENT_NAME] = current.agents[CORE_AGENT_NAME]

    for name, entry in current.agents.items():
        if name == CORE_AGENT_NAME:
            continue
        if name in remove_names:
            removed_from_registry.append(name)
            if entry.category:
                categories_to_clean.add(entry.category)
            print(f"registry entry removed: {name}")
            continue
        new_agents[name] = entry

    registry_changed = bool(removed_from_registry)

    pruned = AgentRegistryData(
        version=current.version,
        last_updated=datetime.now(timezone.utc),
        agents=new_agents,
    )

    used_categories = {e.category for e in new_agents.values() if e.category}
    data_root = _repo_path(AGENT_DATA_ROOT)
    if data_root.is_dir():
        for child in data_root.iterdir():
            if child.is_dir() and child.name not in used_categories:
                categories_to_clean.add(child.name)

    if not dry_run and registry_changed:
        reg_path = _repo_path(REGISTRY_PATH)
        reg_path.parent.mkdir(parents=True, exist_ok=True)
        reg_path.write_text(
            pruned.model_dump_json(indent=2) + "\n",
            encoding="utf-8",
        )
        print("registry written: data/agent_registry.json")

    return pruned, categories_to_clean, registry_changed


def _reset_base(*, dry_run: bool) -> None:
    print("Resetting base data (DB)...")
    db = _repo_path(DB_PATH)
    if dry_run:
        print(f"  (would unlink) {db}")
    else:
        db.unlink(missing_ok=True)
        from storage.core import get_storage, reset_storage

        reset_storage()
        get_storage()
        print("  DB reset (re-seeded from data/seed_crm.json on access)")


def _reset_categories(*, dry_run: bool) -> None:
    print("Resetting categories...")
    cat = _repo_path(CATEGORIES_PATH)
    if dry_run:
        print(f"  (would unlink) {cat}")
    else:
        cat.unlink(missing_ok=True)
        from agents.classification import get_category_tree, reset_category_tree

        reset_category_tree()
        get_category_tree()
        print("  categories.json reset from embedded seed")


def _reset_specialists(
    remove_names: list[str],
    *,
    dry_run: bool,
    no_git: bool,
) -> None:
    if not remove_names:
        return
    print(f"Specialists to remove: {', '.join(remove_names)}")
    _, categories_to_clean, registry_changed = _prune_registry(
        set(remove_names),
        dry_run=dry_run,
    )

    for category in sorted(categories_to_clean):
        data_dir = _repo_path(AGENT_DATA_ROOT / category)
        if dry_run:
            print(f"  (would clean data dir) {data_dir}")
        else:
            print(f"  cleaning data dir: {data_dir}")
        _git_rm(data_dir, recursive=True, dry_run=dry_run, no_git=no_git)
        _remove_path(data_dir, dry_run=dry_run)

    for name in remove_names:
        py_path = _repo_path(SPECIALISTS_DIR / f"{name}.py")
        if dry_run:
            print(f"  (would clean specialist py) {py_path}")
        else:
            print(f"  cleaning specialist py: {py_path}")
        _git_rm(py_path, dry_run=dry_run, no_git=no_git)
        _remove_path(py_path, dry_run=dry_run)

    if not dry_run and not no_git and registry_changed:
        reg = _repo_path(REGISTRY_PATH)
        if reg.exists():
            rel = reg.relative_to(REPO_ROOT)
            if _in_git_repo():
                subprocess.run(
                    ["git", "add", str(rel)],
                    cwd=REPO_ROOT,
                    check=False,
                )
            else:
                print("  [git] warning: not in a git repository; skipping git add")


def _reset_singletons(*, dry_run: bool) -> None:
    print("")
    print("Resetting singletons (registry, factory, classification, storage)...")
    if dry_run:
        print("  (would reset in-process singletons)")
        return
    from agents.classification import reset_category_tree
    from agents.factory.agent_factory import reset_agent_factory
    from agents.registry import reset_agent_registry
    from storage.core import reset_storage

    reset_agent_registry()
    reset_agent_factory()
    reset_category_tree()
    reset_storage()
    print("  singletons reset")


def _confirm(yes: bool, dry_run: bool) -> None:
    if yes or dry_run:
        return
    answer = input(
        "This will delete selected data and may stage git removals. Continue? [y/N] ",
    ).strip()
    if answer.lower() not in {"y", "yes"}:
        print("Aborted.")
        sys.exit(1)


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="bin/reset-mycelium",
        description=(
            "Reset Mycelium dev data on canonical source paths only "
            "(ignores MYCELIUM_* env redirection). Keeps agent_registry.json "
            "in sync when removing generated specialists."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  bin/reset-mycelium --dry-run --all
  bin/reset-mycelium --specialist financial_specialist
  bin/reset-mycelium --specialists --yes
  bin/reset-mycelium --base --categories
  bin/reset-mycelium --specialist demographic_specialist,financial_specialist --no-git
""",
    )
    parser.add_argument("-b", "--base", action="store_true", help="Reset data/mycelium.db")
    parser.add_argument(
        "-c",
        "--categories",
        action="store_true",
        help="Reset data/categories.json",
    )
    parser.add_argument(
        "-s",
        "--specialists",
        action="store_true",
        help="Remove all generated specialists",
    )
    parser.add_argument(
        "--specialist",
        action="append",
        default=[],
        metavar="NAME",
        help="Remove specific specialist(s); repeat or use comma-separated list",
    )
    parser.add_argument(
        "-a",
        "--all",
        action="store_true",
        help="Equivalent to --base --categories --specialists",
    )
    parser.add_argument(
        "-n",
        "--dry-run",
        action="store_true",
        help="Print plan only; no filesystem or git changes",
    )
    parser.add_argument("-y", "--yes", action="store_true", help="Skip confirmation")
    parser.add_argument(
        "--no-git",
        action="store_true",
        help="Filesystem only; skip git rm / git add",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    os.chdir(REPO_ROOT)
    args = _build_parser().parse_args(argv)

    do_base = args.base or args.all
    do_categories = args.categories or args.all
    do_all_specialists = args.specialists or args.all
    specific = _parse_specialist_args(args.specialist)

    if not (do_base or do_categories or do_all_specialists or specific):
        print("No reset targets specified.")
        _build_parser().print_help()
        return 1

    print("=== reset-mycelium ===")
    print(f"  base:        {do_base}")
    print(f"  categories:  {do_categories}")
    if do_all_specialists:
        print("  specialists: True")
    elif specific:
        print(f"  specific:    {', '.join(specific)}")
    print(f"  dry-run:     {args.dry_run}")
    print(f"  git:         {'disabled' if args.no_git else 'enabled'}")
    print("")

    _confirm(args.yes, args.dry_run)

    print("=== Executing ===")

    if do_base:
        _reset_base(dry_run=args.dry_run)
    if do_categories:
        _reset_categories(dry_run=args.dry_run)

    remove_names: list[str] = []
    if do_all_specialists:
        remove_names = _collect_all_specialist_names(_load_registry_data())
    elif specific:
        remove_names = specific

    if remove_names:
        _reset_specialists(
            remove_names,
            dry_run=args.dry_run,
            no_git=args.no_git,
        )

    if do_base or do_categories or remove_names:
        _reset_singletons(dry_run=args.dry_run)

    print("")
    print("Done.")
    if args.dry_run:
        print("Dry-run only — no changes were made.")
    print("Run: git status")
    print(
        "Commit the cleanups if desired, or 'git checkout -- .' to revert this reset.",
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
