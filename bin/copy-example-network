#!/usr/bin/env python3
"""Copy a committed example network into a user network_root."""

from __future__ import annotations

import argparse
import os
import shutil
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
_SRC_ROOT = REPO_ROOT / "src"
_VENV_PYTHON = REPO_ROOT / ".venv" / "bin" / "python3"
_EXAMPLES_ROOT = REPO_ROOT / "examples" / "networks"
_SKIP_NAMES = frozenset(
    {
        "README.md",
        "prepare_seed.py",
        "categories.json",
        "agent_registry.json",
        "agents",
        "checkpoints.sqlite",
        "mycelium.db",
    },
)
_RUNTIME_SUFFIXES = (".db", ".sqlite")


def _should_skip(item: Path) -> bool:
    if item.name in _SKIP_NAMES or item.name.startswith("."):
        return True
    if item.name.endswith((".sqlite-shm", ".sqlite-wal")):
        return True
    return item.is_file() and item.suffix in _RUNTIME_SUFFIXES


def _bootstrap() -> None:
    if _VENV_PYTHON.is_file():
        try:
            if Path(sys.executable).resolve() != _VENV_PYTHON.resolve():
                os.execv(str(_VENV_PYTHON), [str(_VENV_PYTHON), *sys.argv])
        except OSError:
            pass
    src = str(_SRC_ROOT)
    if src not in sys.path:
        sys.path.insert(0, src)


_bootstrap()

from network.registry import register_network  # noqa: E402


def _copy_example(example: str, target: Path) -> list[str]:
    source = _EXAMPLES_ROOT / example
    if not source.is_dir():
        raise ValueError(f"Unknown example network: {example}")
    target.mkdir(parents=True, exist_ok=True)
    copied: list[str] = []
    for item in sorted(source.iterdir()):
        if _should_skip(item):
            continue
        dest = target / item.name
        if item.is_dir():
            shutil.copytree(item, dest, dirs_exist_ok=True)
        else:
            shutil.copy2(item, dest)
        copied.append(item.name)
    return copied


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="bin/copy-example-network",
        description="Copy examples/networks/<name>/ into a network_root directory.",
    )
    parser.add_argument(
        "example",
        help="Example network name (e.g. crm)",
    )
    parser.add_argument(
        "--root",
        required=True,
        metavar="PATH",
        help="Target network_root directory",
    )
    parser.add_argument(
        "--register",
        action="store_true",
        help="Register the network name after copy (requires Phase 3 registry)",
    )
    parser.add_argument(
        "--default",
        action="store_true",
        help="Mark registered network as default (implies --register)",
    )
    parser.add_argument(
        "--name",
        default=None,
        metavar="NAME",
        help="Registry name (default: network.json name or example folder name)",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    args = _build_parser().parse_args(argv)
    target = Path(args.root).expanduser().resolve()
    try:
        copied = _copy_example(args.example, target)
    except ValueError as exc:
        print(f"Error: {exc}", file=sys.stderr)
        return 1

    print(f"Copied {args.example} → {target}")
    for name in copied:
        print(f"  {name}")

    if args.register or args.default:
        reg_name = args.name
        if not reg_name:
            network_json = target / "network.json"
            if network_json.is_file():
                import json

                meta = json.loads(network_json.read_text(encoding="utf-8"))
                reg_name = str(meta.get("name") or args.example)
            else:
                reg_name = args.example
        entry = register_network(reg_name, target, default=args.default)
        suffix = " (default)" if entry.default else ""
        print(f"Registered {entry.name} → {entry.root}{suffix}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
