{
  "version": "1.0",
  "domains": {
    "batting": {
      "specialist": "batting_specialist",
      "tables": ["Batting"],
      "grain": ["playerID", "yearID", "stint", "teamID", "lgID"],
      "conventions": {
        "career_sum": "SUM({column}) GROUP BY playerID",
        "rate_from_aggregates": "For career rate stats from counting columns: SUM each operand across all domain grain rows for playerID, then divide in Python",
        "sqlite_integer_aggregates": "SUM of integer columns returns integers; do not rely on SQL division for ratios"
      },
      "aliases": {
        "career_hr": {"convention": "career_sum", "column": "HR"},
        "career_rbi": {"convention": "career_sum", "column": "RBI"},
        "career_hits": {"convention": "career_sum", "column": "H"}
      },
      "derive_on_miss": true
    },
    "bio": {
      "specialist": "bio_specialist",
      "tables": ["People"],
      "grain": ["playerID"],
      "aliases": {
        "birth_date": {
          "convention": "people_compose",
          "columns": ["birthYear", "birthMonth", "birthDay"],
          "format": "iso_date"
        },
        "debut": {"convention": "people_column", "column": "debut"},
        "bats": {"convention": "people_column", "column": "bats"},
        "throws": {"convention": "people_column", "column": "throws"},
        "birth_city": {"convention": "people_column", "column": "birthCity"},
        "height": {"convention": "people_column", "column": "height"},
        "weight": {"convention": "people_column", "column": "weight"},
        "birth_country": {"convention": "people_column", "column": "birthCountry"},
        "final_game": {"convention": "people_column", "column": "finalGame"},
        "death_date": {
          "convention": "people_compose",
          "columns": ["deathYear", "deathMonth", "deathDay"],
          "format": "iso_date"
        }
      }
    },
    "pitching": {
      "specialist": "pitching_specialist",
      "tables": ["Pitching"],
      "grain": ["playerID", "yearID", "stint", "teamID", "lgID"],
      "conventions": {
        "career_sum": "SUM({column}) GROUP BY playerID on Pitching table",
        "career_era_weighted": "9 * SUM(ER) / (SUM(IPouts) / 3); pool ER and IPouts across all Pitching rows for playerID"
      },
      "aliases": {
        "career_wins": {"convention": "career_sum", "column": "W"},
        "career_losses": {"convention": "career_sum", "column": "L"},
        "career_strikeouts": {"convention": "career_sum", "column": "SO"},
        "career_saves": {"convention": "career_sum", "column": "SV"},
        "career_era": {"convention": "career_era_weighted"}
      }
    },
    "team_season": {
      "specialist": "team_season_specialist",
      "tables": ["Teams"],
      "grain": ["yearID", "teamID", "lgID"],
      "conventions": {
        "team_latest_column": "Latest yearID row per teamID when scope omits yearID; scoped yearID when EntityQuery.scope.yearID is set"
      },
      "aliases": {
        "season_wins": {"convention": "team_latest_column", "column": "W"},
        "season_losses": {"convention": "team_latest_column", "column": "L"},
        "finish_rank": {"convention": "team_latest_column", "column": "Rank"},
        "park": {"convention": "team_latest_column", "column": "park"},
        "runs_scored": {"convention": "team_latest_column", "column": "R"},
        "runs_allowed": {"convention": "team_latest_column", "column": "RA"}
      }
    },
    "fielding": {
      "specialist": "fielding_specialist",
      "tables": ["Fielding"],
      "grain": ["playerID", "yearID", "stint", "teamID", "lgID"],
      "conventions": {
        "career_sum": "SUM({column}) GROUP BY playerID on Fielding table"
      },
      "aliases": {
        "career_games": {"convention": "career_sum", "column": "G"},
        "career_putouts": {"convention": "career_sum", "column": "PO"}
      }
    }
  }
}
