# Mycelium — copy to .env and fill in values

# LangSmith (recommended for tracing to the cloud service)
# Set to "true" (or 1/yes/on) to enable tracing. Requires a valid LANGCHAIN_API_KEY
# for full cloud UI/features. Trace IDs are still captured locally even with invalid key.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_api_key_here  # Create at https://smith.langchain.com/settings . Choose Key Type: Personal Access Token (PAT). This gives lsv2_pt_* prefix. Free tier works for tracing.
LANGCHAIN_PROJECT=mycelium  # This is the name of the tracing project in LangSmith UI where runs will appear. No need to create it manually in the dashboard first — it will be auto-created on the first trace. (Separate from LANGSMITH_PROJECT_ID which is the UUID used only for fancy trace URLs.)

# To disable cloud tracing entirely (no data leaves your machine, no API key needed):
# LANGCHAIN_TRACING_V2=false
# (or unset the var). The app and graph still work; trace_id in responses will be null.

# Optional: full LangSmith trace URLs (see utils.langsmith.get_langsmith_trace_url)
# LANGSMITH_ORG_ID=your-org-uuid
# LANGSMITH_PROJECT_ID=your-project-uuid
# LANGSMITH_UI_BASE_URL=https://smith.langchain.com

# Local development with LangGraph Studio (free local visual debugger for the graph)
# No LangSmith cloud required. See docs or run (use --tunnel to avoid "Failed to initialize Studio TypeError: Failed to fetch"):
#   LANGCHAIN_TRACING_V2=false uv run --with 'langgraph-cli[inmem]' langgraph dev --tunnel
# Then open (or connect to) the Studio UI — it connects to your local server via a secure tunnel.
# The langgraph.json in the project root configures the "mycelium" graph.
# Set LANGCHAIN_TRACING_V2=false above if you want zero cloud interaction.
#
# IMPORTANT: "Local" means the GRAPH EXECUTION runs on your machine.
# The Studio *UI/IDE* (the visual graph view) is a web app at smith.langchain.com/studio.
# The --tunnel just makes your local server reachable from that web UI.
# If you want ZERO internet (no tunnel, no external UI):
#   - Use direct Python: see the "Purely Offline" examples in README.md
#   - Or run `langgraph dev` WITHOUT --tunnel and call the local API at http://127.0.0.1:2024 yourself (curl, etc. — all on your machine).
#
# If you see "domain 'xxx.trycloudflare.com' is not allowed":
#   On the Studio error page, go to Advanced Settings and add both:
#     updated-intensity-disposition-urls.trycloudflare.com
#     https://updated-intensity-disposition-urls.trycloudflare.com
#
# If instead you see "Failed to initialize Studio" / "TypeError: Failed to fetch" / "ConnectionError...":
#   - The tunnel URL changes on every `./bin/run-studio` run. Old ones (e.g. updated-intensity...) become dead (Cloudflare 530 tunnel error).
#   - Always use the *current live* URLs printed in the terminal banner of the running script.
#   - 1. Visit the plain current 🚀 API URL in a tab first and pass CF check.
#   - 2. Fresh tab to smith.langchain.com/studio → "Connect to a local server" → paste the live API URL.
#   - 3. Add new domain in Advanced Settings.
#   - Restart script after any langgraph.json edit. Try Incognito/Firefox.
#   (The exact domain changes every time you run --tunnel; use the one from the error or from the terminal output.)

# Model providers (for future LLM-backed agents)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GROK_API_KEY=xai-your-xai-key

# SQLite paths (defaults: data/mycelium.db, data/checkpoints.sqlite)
MYCELIUM_DB_PATH=data/mycelium.db
MYCELIUM_CHECKPOINT_PATH=data/checkpoints.sqlite
MYCELIUM_SEED_PATH=data/seed_crm.json
