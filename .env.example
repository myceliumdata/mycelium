# Mycelium — copy to .env and fill in values
#
# Framework credentials (this file): API keys and tracing — ONE per machine/clone,
# shared by every network. Not copied into network_root; not per-network.
# Network selection: MYCELIUM_NETWORK_* below (or CLI --network-dir / --network).

# LangSmith (recommended for tracing to the cloud service)
# Set to "true" (or 1/yes/on) to enable tracing. Requires a valid LANGCHAIN_API_KEY
# for full cloud UI/features. Trace IDs are still captured locally even with invalid key.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_api_key_here  # Create at https://smith.langchain.com/settings . Choose Key Type: Personal Access Token (PAT). This gives lsv2_pt_* prefix. Free tier works for tracing.
LANGCHAIN_PROJECT=mycelium  # This is the name of the tracing project in LangSmith UI where runs will appear. No need to create it manually in the dashboard first — it will be auto-created on the first trace. (Separate from LANGSMITH_PROJECT_ID which is the UUID used only for fancy trace URLs.)

# To disable cloud tracing entirely (no data leaves your machine, no API key needed):
# LANGCHAIN_TRACING_V2=false
# (or unset the var). The app and graph still work; trace_id in responses will be null.

# Optional: full LangSmith trace URLs (see utils.langsmith.get_langsmith_trace_url).
# When LANGCHAIN_API_KEY + LANGCHAIN_PROJECT are set, org/project UUIDs are auto-resolved
# via the LangSmith API (cached per process). Override manually if you prefer:
# LANGSMITH_ORG_ID=your-org-uuid
# LANGSMITH_PROJECT_ID=your-project-uuid
# LANGSMITH_UI_BASE_URL=https://smith.langchain.com

# Local development with LangGraph Studio (free local visual debugger for the graph)
# No LangSmith cloud required. See docs or run:
#   ./bin/run-studio
# Then in another terminal:
#   ngrok http 2024
# Then open (or connect to) the Studio UI — it connects to your local server via the ngrok tunnel.
# The langgraph.json in the project root configures the "mycelium" graph.
# Set LANGCHAIN_TRACING_V2=false above if you want zero cloud interaction.
#
# IMPORTANT: "Local" means the GRAPH EXECUTION runs on your machine.
# The Studio *UI/IDE* (the visual graph view) is a web app at smith.langchain.com/studio.
# The tunnel (ngrok) just makes your local server reachable from that web UI.
# If you want ZERO internet (no tunnel, no external UI):
#   - Use direct Python: see the "Purely Offline" examples in README.md
#   - Or run `langgraph dev` (no tunnel) and call the local API at http://127.0.0.1:2024 yourself (curl, etc. — all on your machine).
#
# If you see "domain 'xxx.ngrok.io' is not allowed" (or similar for your tunnel):
#   On the Studio error page, go to Advanced Settings and add both the bare domain and the https:// version.
#
# If instead you see "Failed to initialize Studio" / "TypeError: Failed to fetch" / "ConnectionError...":
#   - The tunnel URL changes on every `./bin/run-studio` + ngrok run. Old ones become dead.
#   - Always use the *current live* URL.
#   - 1. Visit the plain current ngrok API URL in a tab first and complete the ngrok visit/warning page.
#   - 2. Fresh tab to smith.langchain.com/studio → "Connect to a local server" → paste the live URL.
#   - 3. Add new domain in Advanced Settings if prompted.
#   - Restart server after any langgraph.json edit. Try Incognito/Firefox.

# Web search for specialist research (src/tools/web_search.py)
# SEARCH_PROVIDER=tavily   # tavily | exa | brave (default: tavily)
SEARCH_PROVIDER=tavily

# Tavily — https://app.tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Exa — https://dashboard.exa.ai/api-keys
# EXA_API_KEY=your-exa-api-key-here

# Brave Search API — https://api-dashboard.search.brave.com/
# BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Specialist research runner (src/tools/research.py; sync Phase 1)
# MYCELIUM_RESEARCH_MIN_CONFIDENCE=0.6
# MYCELIUM_RESEARCH_MAX_TOOL_ROUNDS=3
# MYCELIUM_RESEARCH_TIMEOUT_SEC=120
# MYCELIUM_RESEARCH_MODEL=gpt-4o-mini   # see LLM models block below
# Retry failed research (pending + last_error) on next query (default on)
# MYCELIUM_RESEARCH_RETRY_PENDING=1
# Also retry bare pending older than N seconds (0 = only pending-with-error)
# MYCELIUM_RESEARCH_RETRY_PENDING_MIN_AGE_SEC=0
# MYCELIUM_RESEARCH_RETRY_PENDING_SEC=0

# LLM — v1 framework paths use langchain_openai.ChatOpenAI only; OPENAI_API_KEY is required.
OPENAI_API_KEY=sk-your-openai-key
# Not wired yet (do not substitute for OPENAI_API_KEY):
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GROK_API_KEY=xai-your-xai-key

# LLM models (per subsystem) — unset defaults to gpt-4o-mini (src/utils/llm_models.py)
#
# Computation codegen: when no recipe exists for a requested attribute, the framework
# LLM-writes Python to compute the value from warehouse/sources, reviews it, then caches.
# Used for both codegen and semantic review. Prefer gpt-4o or stronger — gpt-4o-mini
# often fails on composite stats (e.g. OPS from batting totals).
# MYCELIUM_COMPUTATION_CODEGEN_MODEL=gpt-4o
# MYCELIUM_CLASSIFICATION_MODEL=gpt-4o-mini
# MYCELIUM_ONTOLOGY_MODEL=gpt-4o-mini
# MYCELIUM_RESEARCH_MODEL=gpt-4o-mini
# MYCELIUM_ALIAS_EXPANSION_MODEL=gpt-4o-mini
# Intent normalization: cheap model for label→intent slug (separate from computation codegen)
# MYCELIUM_INTENT_NORMALIZATION_MODEL=gpt-4o-mini
# Optional: agent factory LLM polish (off by default in normal render path)
# MYCELIUM_AGENT_FACTORY_REFINE_MODEL=gpt-4o-mini

# Network selection (optional; see README and docs/plans/networks-terminology.md)
# MYCELIUM_FRAMEWORK_ROOT=/absolute/path/to/mycelium   # repo root; inferred from package if unset
# MYCELIUM_NETWORKS_CONFIG=~/.config/mycelium/networks.json
# MYCELIUM_NETWORK=crm-seeded                           # registered name (MCP alternative to full path)
# MYCELIUM_NETWORK_ROOT=/absolute/path/to/network_root

# Per-path MYCELIUM_* overrides are legacy (pre-Networks). Do not set them in .env —
# they override network_root and can resurrect writes to retired repo-root data/.
# Prefer MYCELIUM_NETWORK / MYCELIUM_NETWORK_ROOT above. Remove any active lines like:
# MYCELIUM_DB_PATH=...
# MYCELIUM_CHECKPOINT_PATH=...
# MYCELIUM_SEED_PATH=...
